doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(content="width=device-width, initial-scale=1" name="viewport")
        title ChargeQuest - Admin Ports
        link(rel="stylesheet" href="/bootstrap/css/bootstrap.min.css")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/custom/css/common.css")

    body
        span#resp.hidden= resp
        span#csid.hidden= csid

        include include/bs5_modals.pug
        include include/admin_navbar.pug

        form#frmAddPort(method="post" action="/admin/cports" onsubmit="return ValidateAdd();")
            input#hdnAPCSID(type="hidden" name="csid")
            #AddModal.modal(tabindex="-1")
                .modal-dialog
                    .modal-content
                        .modal-header
                            h5.modal-title Add Charging Port
                            button.btn-close(aria-label="Close" data-bs-dismiss="modal" type="button")
                        .modal-body
                            .mb-3 
                                label.form-label.text-muted(for="tbAPName") Port Name
                                input#tbAPName.form-control(name="name" type="text" placeholder="e.g. Port C - CCS2 (100kW)")
                                .invalid-feedback Name is required! 
                            .mb-3 
                                label.form-label.text-muted(for="ddAPChargeType") Charger Type
                                select#ddAPChargeType.form-select(name="ctid")
                                .invalid-feedback Charger type is required!
                        .modal-footer
                            button.btn.btn-secondary(data-bs-dismiss="modal" type="button") Close
                            button.btn.btn-primary(type="submit" name="submit_add") Save Port

        form#frmEditPort(method="post" action="/admin/cports" onsubmit="return ValidateEdit();")
            input#hdnEditCPID(type="hidden" name="csid")
            #EditModal.modal(tabindex="-1")
                .modal-dialog
                    .modal-content
                        .modal-header
                            h5.modal-title Edit Charging Port
                            button.btn-close(aria-label="Close" data-bs-dismiss="modal" type="button")
                        .modal-body
                            .mb-3 
                                label.form-label.text-muted(for="tbEditName") Port Name
                                input#tbEditName.form-control(name="name" type="text")
                                .invalid-feedback Name is required! 
                            .mb-3 
                                label.form-label.text-muted(for="ddEditChargeType") Charger Type
                                select#ddEditChargeType.form-select(name="ctid")
                                .invalid-feedback Charger type is required!
                            .mb-3
                                label.form-label.text-muted(for="ddEditStatus") Status
                                select#ddEditStatus.form-select(name="status")
                                    option(value='-1') --Select Status--
                                    option(value='Active') Active 
                                    option(value='Inactive') Inactive
                                    option(value='Occupied') Occupied
                                    option(value='Reserved') Reserved
                                .invalid-feedback Status is missing.
                        .modal-footer
                            button.btn.btn-secondary(data-bs-dismiss="modal" type="button") Close
                            button.btn.btn-primary(type="submit" name="submit_edit") Save Changes
        
        form#frmDeletePort(method="post" action="/admin/cports" onsubmit="return ValidateEdit();")
            input#hdnDelCPID(type="hidden" name="csid")
            #DeleteModal.modal(tabindex="-1")
                .modal-dialog
                    .modal-content
                        .modal-header
                            h5.modal-title Delete Charging Port
                            button.btn-close(aria-label="Close" data-bs-dismiss="modal" type="button")
                        .modal-body
                            p.text-muted.mb-0 Are you sure you want to delete this charging port?
                        .modal-footer
                            button.btn.btn-secondary(data-bs-dismiss="modal" type="button") Close
                            button.btn.btn-danger(type="submit" name="submit_del") Delete


        .container.mb-5 
            .row 
                .col-12 
                    .glass-card
                        h3.mb-4 Manage Station Charging Ports 
                        
                        .mb-3
                            label.form-label.text-muted Select station to filter ports
                            select#ddSelectCS.form-select(name="csid")
                                option(value='-1') --Select Charging Station --
                        
                        button#btnTriggerAddPort.btn.btn-primary.mb-4(type="button")
                            i.fa-solid.fa-plus.me-2
                            | Add Charging Port
                        
                        .table-responsive
                            table#tblCSPorts.table.table-glass
                                thead   
                                    tr 
                                        th #
                                        th Port Name 
                                        th Type
                                        th Status 
                                        th Actions 
                                tbody

        include include/footer.pug
        
        script(src="/bootstrap/js/bootstrap.bundle.min.js")
        script(src="/jquery/jquery.min.js")
        script(src="/custom/js/bs5_modals.js")
        script(src="/custom/js/admin_cports.js")