doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(content="width=device-width, initial-scale=1" name="viewport")
        title ChargeQuest - User Login
        link(rel="stylesheet" href="/bootstrap/css/bootstrap.min.css")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/custom/css/common.css")
        style.
            .login-container {
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
            }
            .login-bg-glow {
                position: absolute;
                width: 300px;
                height: 300px;
                background: radial-gradient(circle, rgba(16, 185, 129, 0.25) 0%, rgba(0,0,0,0) 70%);
                top: 20%;
                left: 30%;
                z-index: -1;
                filter: blur(40px);
            }
            .login-bg-glow-2 {
                position: absolute;
                width: 350px;
                height: 350px;
                background: radial-gradient(circle, rgba(6, 182, 212, 0.2) 0%, rgba(0,0,0,0) 70%);
                bottom: 20%;
                right: 25%;
                z-index: -1;
                filter: blur(50px);
            }

    body
        span#resp.hidden= resp
        
        .login-bg-glow
        .login-bg-glow-2

        .container.login-container
            .row.w-100.justify-content-center
                .col-lg-5.col-md-7.col-12
                    .text-center.mb-4
                        img.mb-3(src="/media/applogo.svg" alt="logo" style="width: 80px; filter: drop-shadow(0 0 15px rgba(16,185,129,0.5));")
                        h1.mb-1.fw-extrabold.text-white ChargeQuest
                        p.text-muted Smart EV Charging Network

                    .glass-card.p-4
                        h3.text-center.mb-4.text-white Sign In
                        
                        form#frmLogin(method="post" action="/user/login" onsubmit="return ValidateLogin();")
                            .form-group.mb-3
                                label.form-label.text-muted(for="tbLogin") Email Address
                                .input-group
                                    span.input-group-text.bg-dark.border-secondary
                                        i.fa-solid.fa-envelope.text-muted
                                    input#tbLogin.form-control(type="email" name="login" placeholder="name@example.com")
                                    .invalid-feedback Email ID is required!
                            
                            .form-group.mb-4
                                label.form-label.text-muted(for="tbPasswd") Password
                                .input-group
                                    span.input-group-text.bg-dark.border-secondary
                                        i.fa-solid.fa-lock.text-muted
                                    input#tbPasswd.form-control(type="password" name="passwd" placeholder="••••••••")
                                    .invalid-feedback Password is required!
                            
                            .mb-3
                                button.btn.btn-primary.w-100(type="submit" name="submit_login")
                                    i.fa-solid.fa-arrow-right-to-bracket.me-2
                                    | Login
                            
                            .text-center.mt-3
                                span.text-muted.small Don't have an account? 
                                a.small.text-success.fw-bold.text-decoration-none(href="/user/signup") Sign Up

        script(src="/bootstrap/js/bootstrap.bundle.min.js")
        script(src="/jquery/jquery.min.js")
        script(src="/custom/js/user_login.js")