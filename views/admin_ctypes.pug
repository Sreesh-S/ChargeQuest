doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(content="width=device-width, initial-scale=1" name="viewport")
        title ChargeQuest - Admin Dashboard
        link(rel="stylesheet" href="/bootstrap/css/bootstrap.min.css")
        link(rel="stylesheet" 
            href="/fonts/fonts.css")
        link(rel="stylesheet" 
            href="/fonts/materialdesignicons.min.css")
        link(rel="stylesheet" 
            href="/FA4/css/font-awesome.min.css")
        link(rel="stylesheet" 
            href="/custom/css/common.css")
        link(rel="stylesheet" 
            href="/custom/css/admin_ctypes.css")

    body.position-relative
        span#resp.hidden= resp
        span#ctlist.hidden= ctlist

        include include/bs5_modals.pug
        include include/admin_navbar.pug

        form#frmEdit(method="post" action="/admin/ctypes" onsubmit="return ValidateEdit();")
            input#hdnEditCTID(type="hidden" name="ctid")
            #EditModal.modal(tabindex="-1")
                .modal-dialog
                    .modal-content
                        .modal-header
                            h5.modal-title Edit Charger Type
                            button.btn-close(aria-label="Close" data-bs-dismiss="modal" type="button")
                        .modal-body
                            .form-group.mt-5.mb-3
                                label.form-label(for="tbEditName") Charger type name
                                input#tbEditName.form-control(type="text" name="ctname")
                                .invalid-feedback Name is required!
                            .form-group.mb-3
                                label.form-label(for="tbEditDesc") Charger type description
                                textarea#tbEditDesc.form-control(type="text" name="ctdesc" rows="2" style="resize:none;")
                                .invalid-feedback Description is required!

                        .modal-footer
                            button.btn.btn-secondary(
                                data-bs-dismiss="modal" 
                                type="button"
                                ) Close
                            button.btn.btn-primary(type="submit" name="submit_edit") Save changes

        form#frmDelete(method="post" action="/admin/ctypes")
            input#hdnDeleteCTID(type="hidden" name="ctid")
            #DeleteModal.modal(tabindex="-1")
                .modal-dialog
                    .modal-content
                        .modal-header
                            h5.modal-title Delete Charger Type
                            button.btn-close(aria-label="Close" data-bs-dismiss="modal" type="button")
                        .modal-body
                            p Are you sure ...

                        .modal-footer
                            button.btn.btn-secondary(
                                data-bs-dismiss="modal" 
                                type="button"
                                ) Close
                            button.btn.btn-danger(type="submit" name="submit_del") Confirm Delete

        .container 
            .row 
                .col-lg-4.col-md-4.col-sm-12.col-xs-12 
                    form#frmAdd(method="post" action="/admin/ctypes" onsubmit="return ValidateAdd();")
                        .card.mt-5 
                            .card-body 
                                .h3 Add Charger Type
                                .form-group.mt-5.mb-3
                                    label.form-label(for="tbName") Charger type name
                                    input#tbName.form-control(type="text" name="ctname")
                                    .invalid-feedback Name is required!
                                .form-group.mb-3
                                    label.form-label(for="tbDesc") Charger type description
                                    textarea#tbDesc.form-control(type="text" name="ctdesc" rows="2" style="resize:none;")
                                    .invalid-feedback Description is required!

                                .form-group.mt-5
                                    button.btn.btn-primary.btn-lg.w-100(type="submit" name="submit_add") Add

                .col-lg-8.col-md-8.col-sm-12.col-xs-12 
                    .card.mt-5 
                        .card-body 
                            h3 Charger Type List
                            table#tblCTList.table.table-striped.table-hover
                                thead 
                                    tr 
                                        th #
                                        th Name 
                                        th Description 
                                        th Actions 
                                tbody 

        include include/footer.pug

        script(src="/bootstrap/js/bootstrap.bundle.min.js")
        script(src="/jquery/jquery.min.js")
        script(src="/custom/js/bs5_modals.js")
        script(src="/custom/js/admin_ctypes.js")